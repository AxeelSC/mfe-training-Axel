{
  "name": "mfe-training-axel",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "run:all": "node node_modules/@angular-architects/module-federation/src/server/mf-dev-server.js",
    "start:shell": "ng serve shell --port 4200",
    "start:catalog": "ng serve catalog --port 4201",
    "start:reports": "ng serve reports --port 4202",
    "start:front": "concurrently npm:start:catalog npm:start:reports npm:start:shell"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-architects/module-federation": "^21.2.2",
    "@angular-devkit/build-angular": "^21.2.14",
    "@angular/build": "^21.2.14",
    "@angular/cli": "^21.2.14",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^10.0.3",
    "jsdom": "^28.0.0",
    "ngx-build-plus": "^20.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "webpack": "^5.105.2",
    "webpack-cli": "^7.0.3"
  }
