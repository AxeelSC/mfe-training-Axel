                "output": "."
              }
            ],
            "styles": ["projects/catalog/src/styles.scss"],
            "outputPath": "dist/catalog",
            "main": "projects/catalog/src/main.ts",
            "index": "projects/catalog/src/index.html",
            "extraWebpackConfig": "projects/catalog/webpack.config.js",
            "commonChunk": false
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "extraWebpackConfig": "projects/catalog/webpack.prod.config.js"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "ngx-build-plus:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "catalog:build:production",
              "extraWebpackConfig": "projects/catalog/webpack.prod.config.js"
            },
            "development": {
              "buildTarget": "catalog:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 4201,
            "publicHost": "http://localhost:4201",
            "extraWebpackConfig": "projects/catalog/webpack.config.js"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
    "reports": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/reports",
      "sourceRoot": "projects/reports/src",
      "prefix": "app",
